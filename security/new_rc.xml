<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="vechicle_repair_rule_two" model="ir.rule">
        <field name="name">vehicle repair record rules</field>
        <field name="model_id" ref="model_vechicle_service" />
        <field name="groups" eval="[(4, ref('vechicle_repair_management.group_technician_two'))]"/>
        <field name="domain_force">[('create_uid', '=', user.id)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval='False'/>
    </record>


    <record id="vechicle_repair_rule_company_tag" model="ir.rule">
        <field name="name">vehicle repair record rules for company for tag</field>
        <field name="model_id" ref="model_vehicle_tag"/>
        <field name="domain_force">['|',
            ('company_id', '=', False),
            ('company_id', 'in', company_ids)]
        </field>
        <field name="global" eval="True"/>
    </record>



</odoo>