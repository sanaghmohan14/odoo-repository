<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Template to send Sale Order email to the customer -->
    <record id="vehicle_service_template" model="mail.template">
        <field name="name">vehicle.service.template</field>
        <field name="name">my service template</field>
        <field name="email_from">{{object.partner_id.email }}</field>
        <field name="email_to">{{ object.partner_id.email }}</field>
<!--        <field name="subject">Your service order {{ object.name }}</field>-->
        <field name="body_html" type="html">
            <div style="font-family: Arial, sans-serif; font-size: 14px; color: #333;">
                <p>Dear
                    <strong>
                        <t t-out="object.partner_id.name"/>
                    </strong>
                </p>
                <p>
                    Thank you for your order! Please find the details of your sale order below:
                </p>
            </div>
        </field>
    </record>
</odoo>





