<?xml version="1.0" encoding='UTF-8'?>
<odoo>
    <record id="vehicle_service_automation" model="base.automation">
        <field name="name">Update Customer Status</field>
        <field name="model_id" ref="model_vechicle_service"/>
        <field name="trigger">on_create</field>
        <field name="action_server_ids" eval="[(4, ref('vechicle_service_update_status'))]"/>
    </record>

    <record id="vechicle_service_update_status" model="ir.actions.server">
        <field name="name">Update Customer Status</field>
        <field name="model_id" ref="model_vechicle_service"/>
        <field name="state">code</field>
        <field name="code">
            if record.partner_id:
            record.partner_id.customer_state = 'service'
        </field>
    </record>
</odoo>












