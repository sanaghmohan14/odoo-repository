<?xml version="1.0" encoding='UTF-8'?>
<odoo>

    <record id="customer_state_change" model="ir.actions.server">
        <field name="name">Update Customer Status</field>
        <field name="model_id" ref="model_vechicle_service"/>
        <field name="state">code</field>
        <field name="code">
         if record.partner_id:
            record.partner_id.write({'customer_state': 'service'})
        </field>
    </record>


    <record id="vehicle_service_automation" model="base.automation">
        <field name="name">Update Customer Status</field>
        <field name="model_id" ref="model_vechicle_service"/>
        <field name="trigger">on_create</field>
        <field name="action_server_ids" eval="[(4, ref('vechicle_repair_management.customer_state_change'))]"/>
    </record>


</odoo>












