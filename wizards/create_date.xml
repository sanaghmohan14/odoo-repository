<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <record id="create_date_form" model="ir.ui.view">
        <field name="name">create.date.wizard</field>
        <field name="model">create.date</field>
        <field name="arch" type="xml">
            <form string="create service">
                <group>
                    <field name="end_date"/>
                </group>
                <footer>
                    <button name="action_create_date" string="create date" type="object" class="btn-primary" data-hotkey="q"/>
                    <button string="Discard" class="btn-secondary" special="cancel" data-hotkey="x"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>