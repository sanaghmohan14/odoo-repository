<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_vechicle_repair_management" model="ir.actions.act_window">

        <field name="name">vechicle service</field>
        <field name="res_model">vechicle.service</field>
        <field name="view_mode">list,form</field>
    </record>


    <!-- from view  creation-->
    <record id="vehicle_service_management_view_form" model="ir.ui.view">
        <field name="name">vehicle.service.management.view.form</field>

        <field name="model">vechicle.service</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button string="confirm" type="object" name="action_confirm" invisible="state not in ['draft']"/>


                    <button string="create invoice" type="object" name="action_invoice"
                            invisible="state in [('cancelled'),('draft'),('inprogress')]">

                        <!--                        <field name="invoice_id"></field>-->

                    </button>
                    <button string="Done" type="object"  name="action_done" invisible="state in [('cancelled'),('draft'),('inprogress')] "></button>
                    <button type="object" string="Send Email" name="action_send_mail"></button>


                    <button string="ready for delivery" type="object" name="action_ready_for_delivery"
                            invisible="state not in ['inprogress']"/>
                    <field name="state" widget="statusbar" options="{'clickable':'1'}"/>

                </header>
            <sheet>

                <sheet>
                    <widget name="web_ribbon" title="Paid" bg_color="text-bg-success" invisible="invoice_paid=='unpaid'" />
                    <div name="button_box" class="oe_button_box">
                        <button class="oe_stat_button"
                                type="object" icon="fa-wrench" name="action_service_history">


                            <div class="o_stat_info">

                                <field name="repair_count"/>
                                <field name="service_history" widget="statinfo" string="service history"/>

                            </div>
                        </button>


                        <div name="button_box" class="oe_button_box">
                            <button class="oe_stat_button"
                                    type="object" icon="fa-pencil-square-o" name="action_view_invoice">
                                <div class="o_stat_info">

<!--                                    <field name="invoice_count"/>-->
                                    <field name="invoice_id" widget="statinfo" string="invoice"/>

                                </div>
                            </button>
                        </div>


                    </div>
                    <group>
                        <h2>
                            <field name="name" readonly="1"/>

                        </h2>
                    </group>
                    <group>

                        <group>

                            <field name="partner_id" widget="res_partner_many2one"
                                   context="{'show_address': 1}"
                                   options='{"always_reload": True}' readonly="state not in ['draft']"/>
                            <field name="mobile_number" readonly="state not in ['draft']"/>
                            <field name="email" />
                            <field name="vechicle_no" required="True" readonly="state not in ['draft']"/>
                            <field name="advisor_id" readonly="state not in ['draft']"/>
                            <field name="company_id" readonly="state not in ['draft']"/>
                            <field name="service_tag" widget="many2many_tags" options="{'color_field': 'color'}"/>

                            <filter name="active" string="Active"/>


                        </group>
                        <group>

                            <field name="vechicle_image" widget="image" options='{"size": [100, 100]}'
                                   style="margin-left:300px;margin-top:-60px"
                                   readonly="state not in ['draft']"/>/>
                            <field name="vechicle_type"/>
                            <field name="vehicle_model" domain="[('category_id', '=',vechicle_type)]"
                                   readonly="state not in ['draft']"/>
                            <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color'}"
                                   readonly="state not in ['draft']"/>
                            <field name="service_type" readonly="state not in ['draft']" ondelete="set null"/>
                            <field name="start_date" readonly="state not in ['draft']"/>
                            <field name="duration"/>
                            <field name="end_date" readonly="state not in ['draft']"/>
                            <field name="estimated_amount" readonly="state not in ['draft']"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="labor details" invisible="service_type=='option1'">
                            <form>
                                <field name="labor_working_details_ids">
                                    <list editable="bottom">
                                        <field name="labor_name"/>
                                        <field name="employee_assigned_to_labor"/>
                                        <field name="hourly_cost"/>
                                        <field name="hours_spent"/>
                                        <field name="sub_total_amount"/>
                                    </list>
                                </field>
                                <group>
                                    <from>
                                        <table style="margin-left: 980px;">
                                            <tr>
                                                <td>
                                                    <span>Labor total:</span>
                                                </td>
                                                <td>
                                                    <field string="TOTAL" name="labor_total_amount"
                                                           style="font-size:1.3em; font-weight:bold"/>
                                                </td>
                                            </tr>
                                            <tr>
                                                <td>
                                                    <span>Total:</span>
                                                </td>
                                                <td>
                                                    <field string="Total amount" name="total_sum"
                                                           style="font-size:1.3em; font-weight:bold"/>
                                                </td>
                                            </tr>
                                        </table>
                                    </from>
                                </group>

                            </form>
                        </page>
                        <page string="consumed parts details">
                            <form>
                                <field name="consumed_parts_ids">
                                    <list editable="bottom">
                                        <field name="product_id"/>
                                        <field name="quantity"/>
                                        <field name="unit_price"/>
                                        <field name="sub_total_price"/>
                                    </list>
                                </field>

                            </form>
                            <form>
                                <table style="margin-left: 980px;">
                                    <tr>
                                        <td>
                                            <span>Product Total:</span>
                                        </td>
                                        <td>
                                            <field string="TOTAL" name="total"
                                                   style="font-size:1.3em; font-weight:bold"/>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>
                                            <span>Total:</span>
                                        </td>
                                        <td>
                                            <field string="Total amount" name="total_sum"
                                                   style="font-size:1.3em; font-weight:bold"/>
                                        </td>
                                    </tr>
                                </table>
                            </form>

                        </page>
                        <page string="customer complaint">
                            <p>
                                Add customer complaint here
                                <field name="customer_compliant"/>
                            </p>
                        </page>


                    </notebook>

                </sheet>
                <chatter/>
                </sheet>
            </form>
        </field>
    </record>
    <!-- tree view for from -->
    <record id="vehicle_service_management_tree_views" model="ir.ui.view">
        <field name="name">vehicle.service.management.view.form</field>
        <field name="model">vechicle.service</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="partner_id"/>
                <field name="end_date"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="vehicle_service_management_search_views" model="ir.ui.view">
        <field name="name">vehicle.service.management.view.search</field>
        <field name="model">vechicle.service</field>
        <field name="arch" type="xml">
            <search>
                <field name="partner_id"/>
                <field name="vechicle_type"/>
                <field name="name"/>
                <field name="state"/>
                <field name="vechicle_no"/>
                <field name="advisor_id"/>
                <field name="employee_assigned_to_labor"/>
                <filter name="state" string="filter by state"/>
                <filter name="state" string="filter by draft" domain="[('state', '=', 'draft')]"/>
                <filter name="state" string="filter by inprogress" domain="[('state', '=', 'inprogress')]"/>
                <filter name="state" string="filter by cancelled" domain="[('state', '=', 'cancelled')]"/>
                <filter name="state" string="filter by ready" domain="[('state', '=', 'ready')]"/>
                <filter name="group_by_customer" string="customer" context="{'group_by':'partner_id'}"/>
                <filter name="group_by_state" string="state" context="{'group_by':'state'}"/>
                <filter name="group_by_vechicle_type" string="vehicle_type" context="{'group_by':'vechicle_type'}"/>
                <filter name="group_by_vechicle_type" string="vehicle_type"
                        context="{'group_by':'employee_assigned_to_labor'}"/>
                <filter name="Active" string="archived" domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>

</odoo>